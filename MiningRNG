-- Tabela fixa baseada no módulo do jogo
local OreBaseHealth = {
	["Stone"] = 50,
	["Coal"] = 150,
	["Copper"] = 350,
	["Iron"] = 600,
	["Gold"] = 1000,
	["Diamond"] = 4000,
	["Emerald"] = 6000,
