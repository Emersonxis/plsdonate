	["Mirrorite"] = 10000
}

local PresetOresList = {
	"Todos", "Stone", "Coal", "Copper", "Iron", "Gold", "Diamond", 
	"Emerald", "Ruby", "Topaz", "Amethyst", "Sapphire", 
	"Obsidian", "Opal", "Crimsonite", "Aetherite", "Galaxite", 
	"Meteor", "Mirrorite"
}

-- Variáveis de Controle
local selectedOres = {}
local priorityMode = "Menor Vida"
local autoTpActive = false
local autoRollActive = false

-- Sistema de Fila Dinâmica
local targetQueue = {}

local function getOreHealth(ore)
    return ore:GetAttribute("Health") or OreBaseHealth[ore.Name] or 0
end

-- Verifica posicionamento estrito na Zona 9
local function isOreOnZone9(ore)
    if not GroundPart then return false end
    local orePosition = ore:GetPivot().Position
    local localPos = GroundPart.CFrame:PointToObjectSpace(orePosition)
    local size = GroundPart.Size
    
    local insideX = math.abs(localPos.X) <= (size.X / 2)
    local insideZ = math.abs(localPos.Z) <= (size.Z / 2)
    local aboveY = localPos.Y >= -(size.Y / 2)
    
    return insideX and insideZ and aboveY
end

-- Validador de Alvo com base na Regra Geográfica de Tiers
local function isValidTarget(ore)
    local isSelected = table.find(selectedOres, "Todos") or table.find(selectedOres, ore.Name)
    if not isSelected or getOreHealth(ore) <= 0 then return false end
    
    local baseHealth = OreBaseHealth[ore.Name] or 0
    
    -- Se for Diamante (4000 HP) ou superior, libera para o mapa inteiro
    if baseHealth >= 4000 then
        return true
    else
        -- Se for inferior (Stone, Coal, Copper, Iron, Gold), restringe apenas à Área 9
        return isOreOnZone9(ore)
    end
end

local function updateQueue()
    -- Filtra e valida os elementos que já estão na fila
    for i = #targetQueue, 1, -1 do
        local ore = targetQueue[i]
        if not ore or ore.Parent ~= workspace.Ores or not isValidTarget(ore) then
            table.remove(targetQueue, i)
        end
    end

    if #targetQueue >= 2 then return end

    -- Busca novos alvos válidos pelo Workspace de acordo com as regras de tier
    local validOres = {}
    for _, ore in ipairs(workspace.Ores:GetChildren()) do
        if isValidTarget(ore) and not table.find(targetQueue, ore) then
            table.insert(validOres, ore)
        end
    end

    -- Ordenação de prioridade (Maior ou Menor Vida)
    if priorityMode == "Maior Vida" then
        table.sort(validOres, function(a, b)
            return getOreHealth(a) > getOreHealth(b)
        end)
    else
        table.sort(validOres, function(a, b)
            return getOreHealth(a) < getOreHealth(b)
        end)
    end

    -- Abastece as vagas prioritárias
    for i = 1, #validOres do
        if #targetQueue >= 2 then break end
        table.insert(targetQueue, validOres[i])
    end
end

-- Loop de Teleporte (Fila Dinâmica + Damage Check de 2s + Altura de 10 Studs)
local lastTrackedTarget = nil
local lastTeleportTime = 0
local initialHealth = 0
local checkedDamage = false

task.spawn(function()
    while task.wait(0.05) do
        if autoTpActive and #selectedOres > 0 then
            updateQueue()
            
            local currentTarget = targetQueue[1]
            local character = LocalPlayer.Character
            local hrp = character and character:FindFirstChild("HumanoidRootPart")
            
            if hrp and currentTarget then
                if currentTarget ~= lastTrackedTarget then
                    lastTrackedTarget = currentTarget
                    hrp.CFrame = currentTarget:GetPivot() + Vector3.new(0, 10, 0)
                    lastTeleportTime = os.clock()
                    initialHealth = getOreHealth(currentTarget)
                    checkedDamage = false
                end
                
                if os.clock() - lastTeleportTime >= 2 and not checkedDamage then
                    local currentHealth = getOreHealth(currentTarget)
                    if currentHealth >= initialHealth then
                        hrp.CFrame = currentTarget:GetPivot() + Vector3.new(0, 10, 0)
                        lastTeleportTime = os.clock()
                        initialHealth = currentHealth
                    else
                        checkedDamage = true
                    end
                end
                
                local distance = (hrp.Position - currentTarget:GetPivot().Position).Magnitude
                if distance > 25 then
                    hrp.CFrame = currentTarget:GetPivot() + Vector3.new(0, 10, 0)
                end
            else
                lastTrackedTarget = nil
            end
        else
            lastTrackedTarget = nil
            table.clear(targetQueue)
        end
    end
end)

