-- Sistema Customizado de Salvamento JSON (Bypass de erros do Executor)
local function saveCustomConfig()
    local data = {
        selectedOres = selectedOres,
        priorityMode = priorityMode,
        autoTpActive = autoTpActive,
        autoRollActive = autoRollActive
    }
    local success, str = pcall(function() return HttpService:JSONEncode(data) end)
    if success then
        writefile(configFileName, str)
    end
end

