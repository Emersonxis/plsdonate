-- Função Estável para Carregar Dados Salpos pelo Delta
local function loadCustomConfig()
    if isfile(configFileName) then
        local content = readfile(configFileName)
        local success, data = pcall(function() return HttpService:JSONDecode(content) end)
        if success and data then
            if data.selectedOres then 
                selectedOres = data.selectedOres 
                OreDropdown:Set(selectedOres)
            end
            if data.priorityMode then 
                priorityMode = data.priorityMode 
                PriorityDropdown:Set({priorityMode})
            end
            if data.autoTpActive ~= nil then 
                autoTpActive = data.autoTpActive 
                TpToggle:Set(autoTpActive)
            end
            if data.autoRollActive ~= nil then 
                autoRollActive = data.autoRollActive 
                RollToggle:Set(autoRollActive)
            end
        end
    end
end

-- Executa a leitura dos dados salvos após renderizar a UI
task.spawn(loadCustomConfig)
