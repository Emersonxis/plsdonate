-- ==========================================
-- 4. OTIMIZAÇÃO: SISTEMA DE CACHE BLINDADO E ESTÁTICO
-- ==========================================
local ColetoresEmCache = {}

task.spawn(function()
    while true do
        task.wait(5)
        local meuPlot = nil
        for _, p in pairs(workspace.Plots:GetChildren()) do
            local h = p:FindFirstChild("HolderName", true)
            if h and h.Text == player.DisplayName then
                meuPlot = p
                break
            end
        end

        if meuPlot then
            local novosColetores = {}
            for _, bld in pairs(meuPlot.Buildings:GetChildren()) do
                local primary = bld:FindFirstChild("Primary")
                local info = primary and primary:FindFirstChild("Info")
                local valObj = info and info:FindFirstChild("Main") and info.Main:FindFirstChild("Value")
                
                if valObj and primary and info then
                    -- Guardamos o Primary, o Valor e a pasta Info separadamente
                    table.insert(novosColetores, {
                        Primary = primary, 
                        Valor = valObj, 
                        Info = info, 
                        Building = bld
                    })
                end
            end
            ColetoresEmCache = novosColetores
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(0.05) 
        if ColetarTodos then
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            
            if root then
                for _, dados in pairs(ColetoresEmCache) do
                    if not ColetarTodos then break end
                    
                    if dados.Primary and dados.Valor and dados.Primary.Parent then
                        local ok, atual, maximo = pcall(function()
                            return string.match(dados.Valor.ContentText, "(%d+)/(%d+)")
                        end)
                        
                        if ok and atual and maximo and tonumber(atual) >= tonumber(maximo) then
                            local primary = dados.Primary
                            local infoFolder = dados.Info
                            local building = dados.Building
                            
                            local posOri = primary.CFrame
                            
                            -- [MELHORIA] Desacopla a pasta Info para ela não teleportar
                            infoFolder.Parent = building
                            
                            -- Teleporta só a Primary
                            primary.CFrame = root.CFrame
                            firetouchinterest(root, primary, 0)
                            task.wait(0.05)
                            firetouchinterest(root, primary, 1)
                            
                            -- Volta a Primary para o lugar
                            primary.CFrame = posOri
                            
                            -- [MELHORIA] Devolve a pasta Info para dentro da Primary
                            infoFolder.Parent = primary
                        end
                    end
                end
            end
        end
    end
end)

