--[[
    NAME: Zombies Auto Kill
    VERSION: 4.0.0
    STATUS: Permanent Anti-Waste & Panic Mode Ready
]]

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local mobFolder = workspace:WaitForChild("Characters")
local camera = workspace.CurrentCamera

-- Configurações e Armazenamento
local mobBlacklist = {} 
local healthHistory = {} 
local EXP_PanicMode = false -- Função Experimental 1

-- Limpeza periódica da Blacklist (Roda em segundo plano)
task.spawn(function()
    while true do
        task.wait(5)
        mobBlacklist = {} -- Dá uma nova chance aos mobs bugados a cada 5 segundos
    end
end)

-- Controle do Chat (Comando 1)
player.Chatted:Connect(function(msg)
    if msg == "1" then
        EXP_PanicMode = not EXP_PanicMode
    end
end)

-- Visibilidade Estrita (Centro da Cabeça)
local function isStrictlyVisible(mob)
    local char = player.Character
    local head = mob:FindFirstChild("Head")
    if not char or not head then return false end

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {char, camera, mob}
    
    local origin = camera.CFrame.Position
    local direction = (head.Position - origin)
    local result = workspace:Raycast(origin, direction, rayParams)

    return result == nil
end

-- Lista de Alvos por Proximidade
local function getPrioritizedTargets()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return {} end

    local validMobs = {}

    for _, mob in ipairs(mobFolder:GetChildren()) do
        local mRoot = mob:FindFirstChild("HumanoidRootPart")
        local mHum = mob:FindFirstChildOfClass("Humanoid")
        
        if mRoot and mHum and mHum.Health > 0 and not Players:GetPlayerFromCharacter(mob) then
            if not mobBlacklist[mob] then
                local dist = (root.Position - mRoot.Position).Magnitude
                if isStrictlyVisible(mob) then
                    table.insert(validMobs, {instance = mob, distance = dist, health = mHum.Health})
                end
            end
        end
    end

    table.sort(validMobs, function(a, b)
        return a.distance < b.distance
    end)

    return validMobs
end

-- Loop Principal de Combate
task.spawn(function()
    while true do
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local tool = char and char:FindFirstChildOfClass("Tool")
        local shootEvent = tool and tool:FindFirstChild("Shoot")

        if char and root and shootEvent then
            local prioritizedList = getPrioritizedTargets()
            
            -- Lógica do Modo Pânico (Overdrive)
            local isPanicking = false
            if EXP_PanicMode and #prioritizedList > 0 then
                -- Se o mob mais próximo estiver a menos de 15 studs, entra em pânico
                if prioritizedList[1].distance <= 15 then
                    isPanicking = true
                end
            end

            -- Configurações dinâmicas de disparo
            local maxTargets = isPanicking and 6 or 3     -- Mata até 6 no pânico, 3 no normal
            local loopDelay = isPanicking and 0.05 or 0.15 -- Atira 3x mais rápido no pânico

            for i = 1, math.min(#prioritizedList, maxTargets) do
                local targetData = prioritizedList[i]
                local target = targetData.instance
                local head = target:FindFirstChild("Head")
                local hum = target:FindFirstChildOfClass("Humanoid")

                if head and hum then
                    -- Sistema Anti-Waste (Sempre Ativado)
                    if healthHistory[target] and healthHistory[target] <= hum.Health then
                        healthHistory[target .. "_fails"] = (healthHistory[target .. "_fails"] or 0) + 1
                        if healthHistory[target .. "_fails"] >= 3 then
                            mobBlacklist[target] = true 
                        end
                    else
                        healthHistory[target .. "_fails"] = 0
                    end
                    healthHistory[target] = hum.Health

                    -- Disparo
                    local args = {
                        [1] = root.Position,
                        [2] = {
                            [1] = {
                                ["Target"] = head.Position,
                                ["HitData"] = {{["HitChar"] = target, ["HitPos"] = head.Position, ["HitPart"] = head}}
                            }
                        }
                    }
                    shootEvent:FireServer(unpack(args))
                end
            end
            
            -- Reseta o histórico se a lista estiver vazia para liberar memória
            if #prioritizedList == 0 then
                healthHistory = {}
            end
            
            task.wait(loopDelay)
        else
            task.wait(0.5) -- Espera mais tempo se não tiver arma na mão para poupar CPU
        end
    end
end)
