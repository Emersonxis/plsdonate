--[[
    NAME: Aim Kill Base (Zero Point)
    VERSION: 0.3
    STATUS: Head Center Focus, Ally Filter, Micro-Magnet & Phantom Origin
]]

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local camera = workspace.CurrentCamera
local mobFolder = workspace:FindFirstChild("Characters") or workspace:FindFirstChild("Zombies") or workspace:FindFirstChild("NPCs")

-- ==========================================
-- ⚙️ PAINEL DE CONFIGURAÇÕES / TOGGLES
-- ==========================================
local CONFIG = {
    MaxAura = 200,            
    OneShotMode = true,       
    MagnetEnabled = false,     
    MagnetPower = 1.5,        
    AntiWasteHits = 3         
}

-- Comandos Ativos (Podem ser alterados via Chat)
local TOGGLE_SPOOF = false -- Comando "3" no chat para ligar/desligar

local blacklist = {}
local hitCounts = {} 
local failStats = {}
local healthCache = {}

-- 1. Detecção de Aliados
local function isAlly(mob)
    if mob:FindFirstChild("FollowPrompt", true) then return true end
    if mob.Name == "Fighter" then return true end
    return false
end

-- 2. Filtro Geral
local function isValidMob(mob)
    if not mob then return false end
    if blacklist[mob] then return false end
    if Players:GetPlayerFromCharacter(mob) then return false end
    if mob.Name:lower():find("merchant") then return false end
    if isAlly(mob) then return false end
    
    local hum = mob:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    
    return true
end

-- 3. Verificação Estrita (Meio da Testa)
local function checkForeheadVision(head)
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {player.Character, camera, mobFolder}
    rayParams.IgnoreWater = true

    local origin = camera.CFrame.Position
    local direction = head.Position - origin 
    
    local result = workspace:Raycast(origin, direction, rayParams)
    return result == nil
end

-- 4. Micro-Magnet (Descola da parede 1.5 studs)
local function microMagnet(mob)
    local root = mob:FindFirstChild("HumanoidRootPart")
    local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    
    if root and myRoot then
        local dir = (myRoot.Position - root.Position).Unit
        root.CFrame = root.CFrame + (dir * CONFIG.MagnetPower)
    end
end

-- 5. Cérebro de Seleção
local function getBestSingleTarget()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not mobFolder then return nil end

    local bestMob = nil
    local bestScore = math.huge

    for _, mob in ipairs(mobFolder:GetChildren()) do
        if isValidMob(mob) then
            local head = mob:FindFirstChild("Head") or mob:FindFirstChild("HumanoidRootPart")
            local dist = (head.Position - root.Position).Magnitude

            if dist <= CONFIG.MaxAura then
                local vis = checkForeheadVision(head)

                if not vis and CONFIG.MagnetEnabled then
                    microMagnet(mob)
                end

                if vis then
                    local mobHitCount = hitCounts[mob] or 0
                    local hum = mob:FindFirstChildOfClass("Humanoid")
                    local score = 0

                    if CONFIG.OneShotMode then
                        score = (mobHitCount * 10000) + dist
                        if mobHitCount > 0 then
                            score = score + hum.Health
                        end
                    else
                        score = dist
                    end

                    if score < bestScore then
                        bestScore = score
                        bestMob = {instance = mob, head = head, hum = hum}
                    end
                end
            end
        end
    end

    return bestMob
end

-- 6. Loop de Combate
task.spawn(function()
    while true do
        local char = player.Character
        local tool = char and char:FindFirstChildOfClass("Tool")
        
        if char and tool then
            local shootEvent = tool:FindFirstChild("Shoot") or tool:FindFirstChild("Fire")
            local root = char:FindFirstChild("HumanoidRootPart")

            if shootEvent and root then
                local targetData = getBestSingleTarget()

                if targetData then
                    local mob = targetData.instance
                    local head = targetData.head
                    local hum = targetData.hum

                    -- Anti-Waste Logic
                    if healthCache[mob] and healthCache[mob] <= hum.Health then
                        failStats[mob] = (failStats[mob] or 0) + 1
                        if failStats[mob] >= CONFIG.AntiWasteHits then blacklist[mob] = true end
                    else
                        failStats[mob] = 0
                    end
                    healthCache[mob] = hum.Health

                    -- LÓGICA SPOOF (Origem Fantasma)
                    -- Se o Spoof estiver ligado, a bala "nasce" a 1.5 studs acima da cabeça do zumbi.
                    -- Se estiver desligado, a bala nasce da sua posição atual (Normal).
                    local shotOrigin = root.Position
                    if TOGGLE_SPOOF then
                        shotOrigin = head.Position + Vector3.new(0, 1.5, 0)
                    end

                    local args = {
                        [1] = shotOrigin, -- Origem do disparo (Normal ou Forjada)
                        [2] = {
                            [1] = {
                                ["Target"] = head.Position,
                                ["HitData"] = {{
                                    ["HitChar"] = mob, 
                                    ["HitPos"] = head.Position, 
                                    ["HitPart"] = head
                                }}
                            }
                        }
                    }
                    shootEvent:FireServer(unpack(args))

                    hitCounts[mob] = (hitCounts[mob] or 0) + 1
                    task.wait(0.05)
                else
                    task.wait(0.1)
                end
            else
                task.wait(0.5)
            end
        else
            task.wait(0.5)
        end
    end
end)

-- Sistema de Chat para Toggles
player.Chatted:Connect(function(msg)
    if msg == "3" then
        TOGGLE_SPOOF = not TOGGLE_SPOOF
    end
end)

-- Limpeza Inteligente
task.spawn(function()
    while true do
        task.wait(5)
        for mob, _ in pairs(hitCounts) do
            if not mob or not mob.Parent or not mob:FindFirstChild("Humanoid") or mob.Humanoid.Health <= 0 then
                hitCounts[mob] = nil
                healthCache[mob] = nil
                failStats[mob] = nil
            end
        end
        blacklist = {}
    end
end)
