--[[
    NAME: Zombies Auto Kill
    VERSION: 7.0.0
    STATUS: Strict Visibility & Proximity Refactor
]]

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

-- Pasta de alvos (ajustável conforme o jogo)
local mobFolder = workspace:FindFirstChild("Characters") or workspace:FindFirstChild("Zombies")

-- Configurações Internas
local SETTINGS = {
    MaxDistance = 300,        -- Limite da Aura
    MaxTargets = 1,          -- Alvos simultâneos
    PanicDistance = 50,       -- Gatilho de velocidade
    FailLimit = 2             -- Tiros antes de ignorar mob bugado
}

local blacklist = {}
local healthCache = {}
local failStats = {}

---------------------------------------------------------
-- 1. SISTEMA DE VISIBILIDADE REAL (STRICT RAYCAST)
---------------------------------------------------------
local function hasLineOfSight(mob, head)
    local char = player.Character
    if not char or not head then return false end

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    
    -- Otimização: O raio ignora você, a câmera e TODOS os mobs 
    -- para que um zumbi não bloqueie a visão do que está atrás.
    rayParams.FilterDescendantsInstances = {char, camera, mobFolder}
    rayParams.IgnoreWater = true

    local origin = camera.CFrame.Position
    local direction = (head.Position - origin)
    
    local result = workspace:Raycast(origin, direction, rayParams)

    -- Se o resultado for nil, o caminho está 100% livre.
    -- Se bater em algo, o alvo está atrás de uma parede/obstáculo sólido.
    return result == nil
end

---------------------------------------------------------
-- 2. GERENCIADOR DE PRIORIDADE (MÉTODO RÉGUA/AURA)
---------------------------------------------------------
local function getPrioritizedTargets()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not mobFolder then return {} end

    local validTargets = {}

    for _, mob in ipairs(mobFolder:GetChildren()) do
        local mHum = mob:FindFirstChildOfClass("Humanoid")
        local mHead = mob:FindFirstChild("Head") or mob:FindFirstChild("HumanoidRootPart")

        if mHum and mHum.Health > 0 and mHead and not blacklist[mob] then
            local dist = (root.Position - mHead.Position).Magnitude
            
            -- Filtro 1: Distância máxima
            if dist <= SETTINGS.MaxDistance then
                -- Filtro 2: Visibilidade Real (Raycast)
                if hasLineOfSight(mob, mHead) then
                    table.insert(validTargets, {
                        instance = mob,
                        head = mHead,
                        hum = mHum,
                        dist = dist
                    })
                end
            end
        end
    end

    -- Ordenação Linear: O mais próximo sempre será o index [1]
    table.sort(validTargets, function(a, b)
        return a.dist < b.dist
    end)

    return validTargets
end

---------------------------------------------------------
-- 3. MOTOR DE EXECUÇÃO (LOOP OTIMIZADO)
---------------------------------------------------------
task.spawn(function()
    while true do
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local tool = char and char:FindFirstChildOfClass("Tool")
        local shootEvent = tool and (tool:FindFirstChild("Shoot") or tool:FindFirstChild("Fire"))

        if char and root and shootEvent then
            local targetList = getPrioritizedTargets()
            
            if #targetList > 0 then
                -- Modo Pânico: Se o mob estiver a menos de 50 studs, aumenta a agressividade
                local isPanic = targetList[1].dist <= SETTINGS.PanicDistance
                local count = isPanic and (SETTINGS.MaxTargets + 2) or SETTINGS.MaxTargets
                local delay = isPanic and 0.06 or 0.12

                for i = 1, math.min(#targetList, count) do
                    local data = targetList[i]
                    local mob = data.instance
                    
                    -- Lógica Anti-Desperdício (Smart Check)
                    if healthCache[mob] and healthCache[mob] <= data.hum.Health then
                        failStats[mob] = (failStats[mob] or 0) + 1
                        if failStats[mob] >= SETTINGS.FailLimit then 
                            blacklist[mob] = true 
                        end
                    else
                        failStats[mob] = 0
                    end
                    healthCache[mob] = data.hum.Health

                    -- Disparo via Remote
                    shootEvent:FireServer(root.Position, {
                        [1] = {
                            ["Target"] = data.head.Position,
                            ["HitData"] = {{
                                ["HitChar"] = mob, 
                                ["HitPos"] = data.head.Position, 
                                ["HitPart"] = data.head
                            }}
                        }
                    })
                end
                task.wait(delay)
            else
                task.wait(0.2) -- Sem alvos visíveis: poupa CPU
            end
        else
            task.wait(0.5) -- Sem arma: descanso total do script
        end
    end
end)

-- Limpeza de Cache de 5 em 5 segundos
task.spawn(function()
    while true do
        task.wait(5)
        blacklist = {}
        failStats = {}
        healthCache = {}
    end
end)
