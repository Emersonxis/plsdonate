--[[
    NAME: Aim Kill Base (Zero Point)
    VERSION: 0.1
    STATUS: Rebuilt from scratch. Single Target Focus, Cycle System & Magnet Tech.
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local camera = workspace.CurrentCamera
local mobFolder = workspace:FindFirstChild("Characters") or workspace:FindFirstChild("Zombies") or workspace:FindFirstChild("NPCs")

-- Toggles (Comandos de Chat)
local TOGGLE_CYCLE = false   -- Comando "1"
local TOGGLE_MAGNET = false  -- Comando "2"

local hitCounts = {} -- Registra quantos tiros cada mob levou no modo Cycle

---------------------------------------------------------
-- 1. FILTRO DE ALVOS (IGNORA PLAYERS E MERCHANTS)
---------------------------------------------------------
local function isValidMob(mob)
    if not mob then return false end
    if Players:GetPlayerFromCharacter(mob) then return false end
    if mob.Name:lower():find("merchant") then return false end
    
    local hum = mob:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    
    return true
end

---------------------------------------------------------
-- 2. NOVA DETECÇÃO DE VISIBILIDADE (RAYCAST LIMPO)
---------------------------------------------------------
local function isVisible(targetPart)
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    -- Ignora tudo que for do jogador, a câmera e TODOS os mobs (para não bloquearem a visão uns dos outros)
    rayParams.FilterDescendantsInstances = {player.Character, camera, mobFolder}
    rayParams.IgnoreWater = true

    local origin = camera.CFrame.Position
    local direction = targetPart.Position - origin
    
    local result = workspace:Raycast(origin, direction, rayParams)
    
    -- Se result for nil, significa que não bateu em nenhuma parede.
    return result == nil
end

---------------------------------------------------------
-- 3. TECNOLOGIA MAGNET MOB (PUXA PARA FORA DA PAREDE)
---------------------------------------------------------
local function applyMagnet(mob)
    local root = mob:FindFirstChild("HumanoidRootPart")
    local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    
    if root and myRoot then
        -- Calcula a direção da parede/mob até você e puxa ele 5 studs na sua direção
        local directionToMe = (myRoot.Position - root.Position).Unit
        root.CFrame = root.CFrame + (directionToMe * 5)
    end
end

---------------------------------------------------------
-- 4. AURA DE SELEÇÃO E ORDENAÇÃO (O CÉREBRO)
---------------------------------------------------------
local function getBestSingleTarget()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not mobFolder then return nil end

    local bestMob = nil
    local bestScore = math.huge -- Quanto menor o score, maior a prioridade

    for _, mob in ipairs(mobFolder:GetChildren()) do
        if isValidMob(mob) then
            local head = mob:FindFirstChild("Head") or mob:FindFirstChild("HumanoidRootPart")
            local dist = (head.Position - root.Position).Magnitude

            -- Aura de 200 metros (studs)
            if dist <= 200 then
                local vis = isVisible(head)

                -- Se não estiver visível e o Magnet estiver ON, tenta puxar ele
                if not vis and TOGGLE_MAGNET then
                    applyMagnet(mob)
                    -- Não atira na mesma hora, deixa a física atualizar para o próximo tick
                end

                if vis then
                    local mobHitCount = hitCounts[mob] or 0
                    local hum = mob:FindFirstChildOfClass("Humanoid")
                    local score = 0

                    if TOGGLE_CYCLE then
                        -- SISTEMA DE CICLO (1 Tiro por vez)
                        -- Multiplicador gigante para quem já tomou tiro ir para o fim da fila
                        score = mobHitCount * 10000 
                        
                        if mobHitCount == 0 then
                            score = score + dist -- Se ninguém tomou tiro, foca no mais perto
                        else
                            score = score + hum.Health -- Se todos já tomaram, foca no que tem menos vida
                        end
                    else
                        -- SISTEMA PADRÃO (Foco total no mais perto até morrer)
                        score = dist
                    end

                    -- Tie-breaker: Salva o menor score
                    if score < bestScore then
                        bestScore = score
                        bestMob = {instance = mob, head = head}
                    end
                end
            end
        end
    end

    return bestMob
end

---------------------------------------------------------
-- 5. LOOP DE COMBATE E SEGURANÇA
---------------------------------------------------------
task.spawn(function()
    while true do
        local char = player.Character
        local tool = char and char:FindFirstChildOfClass("Tool")
        
        -- SISTEMA DE SEGURANÇA: Se não tiver arma na mão, o código dorme e não faz nada
        if char and tool then
            local shootEvent = tool:FindFirstChild("Shoot") or tool:FindFirstChild("Fire")
            local root = char:FindFirstChild("HumanoidRootPart")

            if shootEvent and root then
                local targetData = getBestSingleTarget()

                if targetData then
                    local mob = targetData.instance
                    local head = targetData.head

                    -- Dispara
                    shootEvent:FireServer(root.Position, {
                        [1] = {
                            ["Target"] = head.Position,
                            ["HitData"] = {{
                                ["HitChar"] = mob, 
                                ["HitPos"] = head.Position, 
                                ["HitPart"] = head
                            }}
                        }
                    })

                    -- Registra o hit para o sistema de Ciclo funcionar
                    hitCounts[mob] = (hitCounts[mob] or 0) + 1
                    
                    -- Sem delay inútil. Usa a menor fração possível para trocar de alvo instantaneamente se o atual morrer.
                    task.wait(0.05) 
                else
                    task.wait(0.1) -- Procura alvos a cada 0.1s se não achar ninguém
                end
            else
                task.wait(0.5) -- Arma na mão, mas sem o evento de atirar
            end
        else
            task.wait(0.5) -- Sem arma equipada, descansa a CPU
        end
    end
end)

---------------------------------------------------------
-- 6. CONTROLES E LIMPEZA DE MEMÓRIA
---------------------------------------------------------
player.Chatted:Connect(function(msg)
    if msg == "1" then
        TOGGLE_CYCLE = not TOGGLE_CYCLE
        hitCounts = {} -- Reseta o ciclo ao ligar/desligar
    elseif msg == "2" then
        TOGGLE_MAGNET = not TOGGLE_MAGNET
    end
end)

-- Limpa a tabela de hits de mobs que já morreram para não vazar memória
task.spawn(function()
    while true do
        task.wait(5)
        for mob, _ in pairs(hitCounts) do
            if not mob or not mob.Parent or not mob:FindFirstChild("Humanoid") or mob.Humanoid.Health <= 0 then
                hitCounts[mob] = nil
            end
        end
    end
end)
