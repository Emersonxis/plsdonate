    NAME: Zombies Auto Kill
    VERSION: 4.2.0
    STATUS: Fixed Concatenation Error
]]

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local mobFolder = workspace:FindFirstChild("Characters") or workspace:FindFirstChild("Zombies") or workspace:FindFirstChild("NPCs")
local camera = workspace.CurrentCamera

local mobBlacklist = {} 
local healthHistory = {} 
local failCount = {} -- Tabela separada para evitar erro de concatenação
local EXP_PanicMode = false 

-- 1. Visibilidade Flexível
local function isStrictlyVisible(mob)
    local char = player.Character
    local head = mob:FindFirstChild("Head") or mob:FindFirstChild("HumanoidRootPart")
    if not char or not head then return false end

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {char, camera, mob}
    rayParams.IgnoreWater = true
    
    local origin = camera.CFrame.Position
    local direction = (head.Position - origin)
    local result = workspace:Raycast(origin, direction, rayParams)

    if result then
        if result.Instance.CanCollide == false or result.Instance.Transparency > 0.7 then
            return true
        end
        return false 
    end
    return true 
end

-- 2. Régua de Proximidade
local function getPrioritizedTargets()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not mobFolder then return {} end

    local validMobs = {}
    for _, mob in ipairs(mobFolder:GetChildren()) do
        local mRoot = mob:FindFirstChild("HumanoidRootPart")
        local mHum = mob:FindFirstChildOfClass("Humanoid")
        
        if mRoot and mHum and mHum.Health > 0 and not Players:GetPlayerFromCharacter(mob) then
            if not mobBlacklist[mob] then
                local dist = (root.Position - mRoot.Position).Magnitude
                if isStrictlyVisible(mob) then
                    table.insert(validMobs, {instance = mob, distance = dist})
                end
            end
        end
    end
    table.sort(validMobs, function(a, b) return a.distance < b.distance end)
    return validMobs
end

-- 3. Loop Principal
task.spawn(function()
    while true do
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local tool = char and char:FindFirstChildOfClass("Tool")
        local shootEvent = tool and (tool:FindFirstChild("Shoot") or tool:FindFirstChild("Fire"))

        if char and root and shootEvent then
            local prioritizedList = getPrioritizedTargets()
            
            -- Panic Mode Check (Comando 1)
            local isPanicking = false
            if EXP_PanicMode and #prioritizedList > 0 and prioritizedList[1].distance <= 15 then
                isPanicking = true
            end

            local maxTargets = isPanicking and 6 or 3
            local waitTime = isPanicking and 0.07 or 0.12

            for i = 1, math.min(#prioritizedList, maxTargets) do
                local target = prioritizedList[i].instance
                local head = target:FindFirstChild("Head") or target:FindFirstChild("HumanoidRootPart")
                local hum = target:FindFirstChildOfClass("Humanoid")

                if head and hum then
                    -- Anti-Waste Logic (Consertado)
                    if healthHistory[target] and healthHistory[target] <= hum.Health then
                        failCount[target] = (failCount[target] or 0) + 1
                        if failCount[target] >= 5 then 
                            mobBlacklist[target] = true 
                        end
                    else
                        failCount[target] = 0
                    end
                    healthHistory[target] = hum.Health

                    -- Fire
                    local args = {
                        [1] = root.Position,
                        [2] = {
                            [1] = {
                                ["Target"] = head.Position,
                                ["HitData"] = {{["HitChar"] = target, ["HitPos"] = head.Position, ["HitPart"] = head}}
                            }
                        }
                    }
                    shootEvent:FireServer(unpack(args))
                end
            end
            task.wait(waitTime)
        else
            task.wait(0.5)
        end
    end
end)

-- Comandos e Limpeza
player.Chatted:Connect(function(msg) if msg == "1" then EXP_PanicMode = not EXP_PanicMode end end)
task.spawn(function() 
    while true do 
        task.wait(4) 
        mobBlacklist = {} 
        failCount = {} -- Limpa os contadores de falha
    end 
end)
