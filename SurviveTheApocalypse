--[[
    NAME: Zombies Auto Kill
    VERSION: 8.0.0
    STATUS: Priority Fix & NPC/Player Filter
]]

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local camera = workspace.CurrentCamera
local mobFolder = workspace:FindFirstChild("Characters") or workspace:FindFirstChild("Zombies")

local SETTINGS = {
    MaxDistance = 300,
    MaxTargets = 10,
    PanicDistance = 50,
    FailLimit = 5
}

local blacklist = {}
local healthCache = {}
local failStats = {}

-- 1. Filtro de Visibilidade Estrito (Head Only)
local function isHeadVisible(mob, head)
    local char = player.Character
    if not char or not head then return false end

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {char, camera, mobFolder}
    rayParams.IgnoreWater = true

    local origin = camera.CFrame.Position
    local result = workspace:Raycast(origin, (head.Position - origin), rayParams)

    return result == nil
end

-- 2. Coleta e Ordenação (Aura por Proximidade)
local function getSortedAura()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not mobFolder then return {} end

    local targets = {}
    local myPos = root.Position

    for _, mob in ipairs(mobFolder:GetChildren()) do
        -- Filtros Obrigatórios: Ignora Players e Mercadores
        if Players:GetPlayerFromCharacter(mob) then continue end
        if mob.Name:lower():find("merchant") then continue end
        
        local hum = mob:FindFirstChildOfClass("Humanoid")
        local head = mob:FindFirstChild("Head") or mob:FindFirstChild("HumanoidRootPart")

        if hum and hum.Health > 0 and head and not blacklist[mob] then
            local dist = (myPos - head.Position).Magnitude
            
            if dist <= SETTINGS.MaxDistance then
                -- Só adiciona à lista se a cabeça estiver visível
                if isHeadVisible(mob, head) then
                    table.insert(targets, {
                        instance = mob,
                        head = head,
                        hum = hum,
                        dist = dist
                    })
                end
            end
        end
    end

    -- Ordenação: O mais perto de VOCÊ vira o primeiro da lista
    table.sort(targets, function(a, b)
        return a.dist < b.dist
    end)

    return targets
end

-- 3. Motor de Disparo
task.spawn(function()
    while true do
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local tool = char and char:FindFirstChildOfClass("Tool")
        local shootEvent = tool and (tool:FindFirstChild("Shoot") or tool:FindFirstChild("Fire"))

        if char and root and shootEvent then
            local auraList = getSortedAura()
            
            if #auraList > 0 then
                -- Se o primeiro da lista (o mais perto) estiver a 50 studs, entra em Pânico
                local nearestDist = auraList[1].dist
                local isPanic = nearestDist <= SETTINGS.PanicDistance
                
                local maxToKill = isPanic and 12 or 10
                local waitTime = isPanic and 0.05 or 0.12

                for i = 1, math.min(#auraList, maxToKill) do
                    local targetData = auraList[i]
                    local mob = targetData.instance
                    
                    -- Anti-Waste
                    if healthCache[mob] and healthCache[mob] <= targetData.hum.Health then
                        failStats[mob] = (failStats[mob] or 0) + 1
                        if failStats[mob] >= SETTINGS.FailLimit then blacklist[mob] = true end
                    else
                        failStats[mob] = 0
                    end
                    healthCache[mob] = targetData.hum.Health

                    -- Remote Call
                    shootEvent:FireServer(root.Position, {
                        [1] = {
                            ["Target"] = targetData.head.Position,
                            ["HitData"] = {{
                                ["HitChar"] = mob, 
                                ["HitPos"] = targetData.head.Position, 
                                ["HitPart"] = targetData.head
                            }}
                        }
                    })
                end
                task.wait(waitTime)
            else
                task.wait(0.2)
            end
        else
            task.wait(0.5)
        end
    end
end)

-- Reset de Cache
task.spawn(function()
    while true do
        task.wait(4)
        blacklist = {}
        failStats = {}
        healthCache = {}
    end
end)
