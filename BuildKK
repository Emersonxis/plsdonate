        if #currentDrops == 0 then table.insert(currentDrops, "Nenhum") end[cite: 1]
        
        local function ArraysMatch(a, b)
            if #a ~= #b then return false end[cite: 1]
            for i = 1, #a do if a[i] ~= b[i] then return false end end[cite: 1]
            return true[cite: 1]
        end
        
        if not ArraysMatch(LastAlienDrops, currentDrops) then[cite: 1]
            LastAlienDrops = currentDrops[cite: 1]
            AlienDropdown:Refresh(currentDrops, true)[cite: 1]
        end
        
        if AutoAlienCollect and folder then[cite: 1]
            for _, drop in ipairs(folder:GetChildren()) do[cite: 1]
                if not AutoAlienCollect then break end[cite: 1]
                if drop and drop.Parent and string.find(drop.Name, "AlienDrop") then[cite: 1]
                    local prompt = drop:FindFirstChildWhichIsA("ProximityPrompt", true)[cite: 1]
                    local targetPart = drop:IsA("BasePart") and drop or drop:FindFirstChildWhichIsA("BasePart", true)[cite: 1]
                    
                    if prompt and targetPart and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then[cite: 1]
                        LocalPlayer.Character.HumanoidRootPart.CFrame = targetPart.CFrame + Vector3.new(0, 3, 0)[cite: 1]
                        task.wait(0.1)[cite: 1]
                        fireproximityprompt(prompt)[cite: 1]
                        
                        local timeout = 0[cite: 1]
                        while drop and drop.Parent and timeout < 20 do[cite: 1]
                            task.wait(0.05)[cite: 1]
                            timeout = timeout + 1[cite: 1]
                            if timeout % 5 == 0 and drop and drop.Parent then fireproximityprompt(prompt) end[cite: 1]
                        end
                    end
                end
            end
        end
    end
end)

