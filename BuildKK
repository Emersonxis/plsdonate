local function HasTargetSeedOnMap()
    if TargetPrice <= 0 then return false end
    
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    local cashObj = leaderstats and leaderstats:FindFirstChild("Cash")
    local currentBalance = cashObj and ParseTextToNumber(cashObj.Value) or 0

    for i = 1, #ActiveBuySeeds do
        local buyNode = ActiveBuySeeds[i]
        if buyNode and buyNode.Parent then
            local seedGui = buyNode.Parent:FindFirstChild("SeedGui")
            local frame = seedGui and seedGui:FindFirstChild("Frame")
            local infoFrame = frame and frame:FindFirstChild("InfoFrame")
            local costObj = infoFrame and infoFrame:FindFirstChild("Cost")
            
            if costObj then
                local costText = costObj.Text == "" and costObj.ContentText or costObj.Text
                local currentPrice = ParseTextToNumber(costText)
                
                if currentPrice >= TargetPrice and currentBalance >= currentPrice then
                    return true
                end
            end
        end
    end
    return false
end

local function SniperCheckSeedOnMap()
