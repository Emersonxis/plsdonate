local function ParseTextToNumber(text)
    if not text then return 0 end
    local str = string.lower(tostring(text))
    str = string.gsub(str, "[$,]", "") 
    local numStr = string.match(str, "[%d%.]+")
    local letter = string.match(str, "[a-z]+")
    local num = tonumber(numStr)
    if num then
        local multipliers = {k = 1e3, m = 1e6, b = 1e9, t = 1e12, q = 1e15, qd = 1e15, qn = 1e18, sx = 1e21, sp = 1e24, o = 1e27, n = 1e30}
        if letter and multipliers[letter] then return num * multipliers[letter] end
        return num
    end
    return 0
end

local function GetMyPlot()
    local Map = workspace:FindFirstChild("Map")
    local Plots = Map and Map:FindFirstChild("Plots")
    if not Plots then return nil end
    for i = 1, 6 do
        local plot = Plots:FindFirstChild("Plot" .. i)
        if plot then
            local att = plot:FindFirstChild("HomeLabelAttachment")
            if att and #att:GetChildren() > 0 then return plot end
        end
    end
    return nil
end

local function getFarmPlots()
    local out = {}
    local myPlot = GetMyPlot()
    if not myPlot then return out end
    for _, name in ipairs({"FarmPlot", "SecondFloor", "ThirdFloor"}) do
        local node = myPlot:FindFirstChild(name)
        if node then
            local fp = name == "FarmPlot" and node or node:FindFirstChild("FarmPlot")
            if fp then table.insert(out, fp) end
        end
    end
    return out
end

local function getUnfertilizedDirt()
    for _, fp in ipairs(getFarmPlots()) do
        for _, plant in ipairs(fp:GetChildren()) do
            local dirt = plant:FindFirstChild("Dirt")
            if dirt and dirt:GetAttribute("PlantLevel") ~= nil and not dirt:GetAttribute("Fertilized") then 
                return dirt 
            end
        end
    end
    return nil
end

