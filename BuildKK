-- ========================================================
-- SISTEMA DE FILA COM VERIFICAÇÃO ATIVA (QUEEN BEE)
-- ========================================================
task.spawn(function()
    while task.wait(0.1) do
        if AutoHoneycombCollect then
            local folder = GetHoneycombsFolder()
            if folder then
                local items = folder:GetChildren()
                for _, honeycomb in ipairs(items) do
                    -- Se a automação foi desligada no meio do processo, interrompe a fila imediatamente
                    if not AutoHoneycombCollect then break end
                    
                    if honeycomb and honeycomb.Parent and (honeycomb:IsA("BasePart") or honeycomb:IsA("Model")) then
                        local collectPrompt = honeycomb:FindFirstChild("Honeycomb", true) and honeycomb.Honeycomb:FindFirstChild("CollectPrompt")
                        local targetPart = honeycomb:IsA("BasePart") and honeycomb or honeycomb:FindFirstChildWhichIsA("BasePart")
                        
                        if collectPrompt and targetPart and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                            local hrp = LocalPlayer.Character.HumanoidRootPart
                            
                            -- Teleporta e tenta coletar
                            hrp.CFrame = targetPart.CFrame + Vector3.new(0, 2, 0)
                            task.wait(0.1)
                            fireproximityprompt(collectPrompt)
                            
                            -- SISTEMA DE FILA: Espera o item sumir do mapa antes de continuar o loop
                            local timeout = 0
                            while honeycomb and honeycomb.Parent and timeout < 15 do
                                task.wait(0.05)
                                timeout = timeout + 1
                                -- Força o clique novamente caso o jogo dê uma leve travada
                                if timeout % 4 == 0 and honeycomb and honeycomb.Parent then
                                    fireproximityprompt(collectPrompt)
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end)

-- ========================================================
-- SISTEMA DE FILA COM VERIFICAÇÃO ATIVA (ALIEN INVASION)
-- ========================================================
task.spawn(function()
    while task.wait(0.5) do
        local currentDrops = {}
        local folder = GetAlienInvasionFolder()
        if folder then
            for _, drop in ipairs(folder:GetChildren()) do
                if string.match(drop.Name, "AlienDrop") and drop:IsA("BasePart") then 
                    table.insert(currentDrops, drop.Name) 
                end
            end
        end
        if #currentDrops == 0 then table.insert(currentDrops, "Nenhum") end
        
        local function ArraysMatch(a, b)
            if #a ~= #b then return false end
            for i = 1, #a do if a[i] ~= b[i] then return false end end
            return true
        end
        
        if not ArraysMatch(LastAlienDrops, currentDrops) then
            LastAlienDrops = currentDrops
            AlienDropdown:Refresh(currentDrops, true)
        end
        
        -- Execução da Coleta com Fila
        if AutoAlienCollect and folder then
            local items = folder:GetChildren()
            for _, drop in ipairs(items) do
                if not AutoAlienCollect then break end
                
                if drop and drop.Parent and string.match(drop.Name, "AlienDrop") and drop:IsA("BasePart") then
                    local prompt = drop:FindFirstChild("ProximityPrompt")
                    if prompt and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                        local hrp = LocalPlayer.Character.HumanoidRootPart
                        
                        hrp.CFrame = drop.CFrame + Vector3.new(0, 3, 0)
                        task.wait(0.1)
                        fireproximityprompt(prompt)
                        
                        -- SISTEMA DE FILA: Segura o script até que este drop específico suma
                        local timeout = 0
                        while drop and drop.Parent and timeout < 20 do
                            task.wait(0.05)
                            timeout = timeout + 1
                            if timeout % 5 == 0 and drop and drop.Parent then
                                fireproximityprompt(prompt)
                            end
                        end
                    end
                end
            end
        end
    end
end)

