local function ProcessBuySeed(buyNode)
    if not buyNode or not buyNode.Parent then return end
    local parentNode = buyNode.Parent
    local seedGui = parentNode:FindFirstChild("SeedGui")
    
    if seedGui then
        local frame = seedGui:FindFirstChild("Frame")
        local infoFrame = frame and frame:FindFirstChild("InfoFrame")
        local costObj = infoFrame and infoFrame:FindFirstChild("Cost")
        
        if costObj then
            local costText = costObj.Text == "" and costObj.ContentText or costObj.Text
            if costText and costText ~= "" then
                local currentPrice = ParseTextToNumber(costText)
                local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
                local cashObj = leaderstats and leaderstats:FindFirstChild("Cash")
                local currentBalance = cashObj and ParseTextToNumber(cashObj.Value) or 0
                
                if currentPrice >= TargetPrice and currentBalance >= currentPrice then
                    local prompt = buyNode:IsA("ProximityPrompt") and buyNode or buyNode:FindFirstChildWhichIsA("ProximityPrompt")
                    if not prompt then prompt = parentNode:FindFirstChildWhichIsA("ProximityPrompt") end
                    
                    if prompt and not SeedDebounce[prompt] then
                        SeedDebounce[prompt] = true
                        fireproximityprompt(prompt)
                        task.delay(0.2, function() SeedDebounce[prompt] = nil end)
                    end
                end
            end
        end
    end
end

