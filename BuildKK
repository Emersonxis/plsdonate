-- 2. Escuta Global (Pega qualquer spot instantaneamente ao surgir)
workspace.DescendantAdded:Connect(function(desc)
    if desc.Name == "BuySeed" then
        table.insert(ActiveBuySeeds, desc)
        if AutoBuyEnabled and TargetPrice > 0 then
            task.spawn(ProcessBuySeed, desc)
        end
    end
end)

workspace.DescendantRemoving:Connect(function(desc)
    if desc.Name == "BuySeed" then
        RemoveActiveSeed(desc)
    end
end)

-- 3. Loop Paralelo Ultra-Rápido
task.spawn(function()
