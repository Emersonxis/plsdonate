-- Loop: Auto Gear Snipe
task.spawn(function()
    local gearTransaction = Remotes:WaitForChild("Gear", 5):WaitForChild("Transaction", 5)
    while task.wait(0.1) do
        for _, gearName in ipairs(allGearsList) do
            local gear = GearStocks:FindFirstChild(gearName)
            if gear then
                local stock = gear.Value or 0
                
                if StockLabels[gearName] then
                    StockLabels[gearName]:Set(gearName .. " : stock " .. tostring(stock))
                end
                
                local isSelected = SelectedSprays[gearName] or SelectedFertilizers[gearName] or SelectedOthers[gearName]
                
                if AutoGearEnabled and isSelected and stock > 0 and not BuyingDebounce[gearName] and gearTransaction then
                    BuyingDebounce[gearName] = true
                    task.spawn(function()
                        gearTransaction:InvokeServer(gearName)
                        task.wait(0.1)
                        BuyingDebounce[gearName] = false
                    end)
                end
            end
        end
    end
end)
