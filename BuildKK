local function GetHoneyTokenCount()
    local total = 0
    local function scan(parent)
        for _, item in ipairs(parent:GetChildren()) do
            if string.find(item.Name, "Honey Token") then
                local s = string.match(item.Name, "%(x(%d+)%)")
                total = total + (s and tonumber(s) or 1)
            end
        end
    end
    scan(LocalPlayer.Backpack)
    if LocalPlayer.Character then scan(LocalPlayer.Character) end
    return total
end

local function EquipHoneyToken()
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
            if string.find(item.Name, "Honey Token") then hum:EquipTool(item) break end
        end
    end
end

local function GetBackpackStock(plantName)
    local total = 0
    for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if string.find(item.Name, plantName, 1, true) and string.find(item.Name, "Seed", 1, true) then
            local countStr = string.match(item.Name, "%(x(%d+)%)")
            total = total + (countStr and tonumber(countStr) or 1)
        end
    end
    return total
end

