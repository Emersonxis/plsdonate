-- LOOPS: FAZENDA (VARREDURA LIMPA E ANTI-LAG)
-- ========================================================
local UpgradeDebounceTimes = {}

task.spawn(function()
    local upgradeRemote = Remotes:WaitForChild("UpgradePlant", 5)
    local fertRemote = Remotes:WaitForChild("UseFertilizer", 5)
    
    while task.wait(0.5) do
        if AutoUpgradeEnabled and upgradeRemote then
            for _, fp in ipairs(getFarmPlots()) do
                if not AutoUpgradeEnabled then break end
                
                for _, plant in ipairs(fp:GetChildren()) do
                    if not AutoUpgradeEnabled then break end
                    
                    local dirt = plant:FindFirstChild("Dirt")
                    if dirt then
                        local currentLvl = dirt:GetAttribute("PlantLevel") or 0
                        
                        if currentLvl < TargetUpgradeLevel then
                            local lastAttempt = UpgradeDebounceTimes[dirt] or 0
                            
                            -- Só envia novo request se já se passaram 1.5s desde o último envio para esta MESMA planta.
                            -- Isso evita congestionar o servidor com spam da mesma requisição.
                            if tick() - lastAttempt > 1.5 then
                                UpgradeDebounceTimes[dirt] = tick()
                                
                                task.spawn(function()
                                    pcall(function() upgradeRemote:InvokeServer(dirt) end)
                                end)
                                
                                task.wait(0.1) -- Delay global super leve entre plantas para manter a rede lisa
                            end
                        end
                    end
                end
            end
        end
        
        if AutoFertilizerEnabled and fertRemote then
            local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            local tool, dirt = nil, getUnfertilizedDirt()
            
            for _, t in ipairs(LocalPlayer.Backpack:GetChildren()) do
                for allowedName, isActive in pairs(SelectedAutoFertilizers) do
                    if isActive and string.find(t.Name, allowedName, 1, true) then tool = t break end
                end
                if tool then break end
            end
            
            if tool and dirt and humanoid then
                humanoid:EquipTool(tool)
                task.wait(0.3)
                fertRemote:FireServer(dirt)
                task.wait(0.3)
                humanoid:UnequipTools()
            end
        end
    end
end)

-- ========================================================
-- LOOP EXPERIMENTAL: PLANT RUSH (TRACKING DINÂMICO)
-- ========================================================
task.spawn(function()
    local ShootRemote = Remotes:WaitForChild("PlantRush", 5) and Remotes.PlantRush:WaitForChild("Shoot", 5)
    
    while true do
        -- A velocidade do tiro é controlada dinamicamente pelo Input
        task.wait(PlantRushShootSpeed)
        
        if AutoPlantRush and ShootRemote then
            local ie = workspace:FindFirstChild("InteractiveEvents")
            local pr = ie and ie:FindFirstChild("PlantRush")
            local runtime = pr and pr:FindFirstChild("Runtime")
            
            if runtime and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local originPos = LocalPlayer.Character.HumanoidRootPart.Position
                local targetsFired = 0
                
                local currentPlants = runtime:GetChildren()
                local currentPlantsMap = {}
                
                -- Passo 1: Registrar novas plantas e identificar as ativas
                for _, plant in ipairs(currentPlants) do
                    currentPlantsMap[plant] = true
                    if not TrackedPlants[plant] then
                        TrackedPlants[plant] = tick() -- Salva a exata hora em que o mob spawnou
                    end
                end
                
                -- Passo 2: Limpar lixo de plantas que já morreram
                for plant, _ in pairs(TrackedPlants) do
                    if not currentPlantsMap[plant] then
                        TrackedPlants[plant] = nil
                    end
                end
                
                -- Passo 3: Atirar respeitando os limites
                for _, plant in ipairs(currentPlants) do
                    if not AutoPlantRush or targetsFired >= PlantRushMaxTargets then break end
                    
                    local spawnTime = TrackedPlants[plant]
                    
                    -- Verifica se o tempo de vida da planta já superou o Spawn Protection
                    if spawnTime and (tick() - spawnTime) >= PlantRushSpawnProtection then
                        local targetPart = plant:IsA("BasePart") and plant or plant:FindFirstChildWhichIsA("BasePart", true)
                        
                        if targetPart then
                            local targetPos = targetPart.Position
                            local direction = (targetPos - originPos).Unit
                            local args = { originPos, direction, targetPos }
                            
                            task.spawn(function()
                                ShootRemote:FireServer(unpack(args))
                            end)
                            
                            targetsFired = targetsFired + 1
                        end
                    end
                end
            end
        end
    end
end)

