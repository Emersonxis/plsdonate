-- ========================================================
-- FUNÇÃO UNIVERSAL DE CONVERSÃO MATEMÁTICA
-- ========================================================
local function ParseTextToNumber(text)
    if not text then return 0 end
    local str = string.lower(tostring(text))
    str = string.gsub(str, "[$,]", "") 
    
    local numStr = string.match(str, "[%d%.]+")
    local letter = string.match(str, "[a-z]+")
    local num = tonumber(numStr)
    
    if num then
        local multipliers = {
            k = 1e3, m = 1e6, b = 1e9, t = 1e12, 
            q = 1e15, qd = 1e15, qn = 1e18, 
            sx = 1e21, sp = 1e24, o = 1e27, n = 1e30
        }
        
        if letter and multipliers[letter] then
            return num * multipliers[letter]
        end
        return num
    end
    return 0
end

