local function RemoveActiveSeed(item)
    for i = #ActiveBuySeeds, 1, -1 do
        if ActiveBuySeeds[i] == item then table.remove(ActiveBuySeeds, i) end
    end
end

local function RemoveActivePet(item)
    for i = #ActiveBuyPets, 1, -1 do
        if ActiveBuyPets[i] == item then table.remove(ActiveBuyPets, i) end
    end
end

local function HasTargetSeedOnMap()
    if TargetPrice <= 0 then return false end
    
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    local cashObj = leaderstats and leaderstats:FindFirstChild("Cash")
    local currentBalance = cashObj and ParseTextToNumber(cashObj.Value) or 0

    for i = 1, #ActiveBuySeeds do
        local buyNode = ActiveBuySeeds[i]
        if buyNode and buyNode.Parent then
            local seedGui = buyNode.Parent:FindFirstChild("SeedGui")
            local frame = seedGui and seedGui:FindFirstChild("Frame")
            local infoFrame = frame and frame:FindFirstChild("InfoFrame")
            local costObj = infoFrame and infoFrame:FindFirstChild("Cost")
            
            if costObj then
                local costText = costObj.Text == "" and costObj.ContentText or costObj.Text
                local currentPrice = ParseTextToNumber(costText)
                
                if currentPrice >= TargetPrice and currentBalance >= currentPrice then
                    return true
                end
            end
        end
    end
    return false
end

-- Checa Pets usando a MESMA variável de preço (TargetPrice)
local function HasTargetPetOnMap()
    if TargetPrice <= 0 then return false end

    for i = 1, #ActiveBuyPets do
        local buyNode = ActiveBuyPets[i]
        if buyNode and buyNode.Parent then
            local petGui = buyNode.Parent:FindFirstChild("PetGui") or buyNode.Parent:FindFirstChildWhichIsA("BillboardGui")
            local frame = petGui and (petGui:FindFirstChild("Frame") or petGui:FindFirstChildWhichIsA("Frame"))
            local infoFrame = frame and (frame:FindFirstChild("InfoFrame") or frame:FindFirstChild("Frame"))
            local costObj = infoFrame and (infoFrame:FindFirstChild("Cost") or infoFrame:FindFirstChildWhichIsA("TextLabel"))
            
            if costObj then
                local costText = costObj.Text == "" and costObj.ContentText or costObj.Text
                local currentPrice = ParseTextToNumber(costText)
                
                if currentPrice >= TargetPrice then
                    return true
                end
            end
        end
    end
    return false
end

