local UpgradeDebounceTimes = {}

task.spawn(function()
    local upgradeRemote = Remotes:WaitForChild("UpgradePlant", 5)
    local fertRemote = Remotes:WaitForChild("UseFertilizer", 5)
    
    while task.wait(0.5) do
        if AutoUpgradeEnabled and upgradeRemote then
            for _, fp in ipairs(getFarmPlots()) do
                if not AutoUpgradeEnabled then break end
                
                for _, plant in ipairs(fp:GetChildren()) do
                    if not AutoUpgradeEnabled then break end
                    
                    local dirt = plant:FindFirstChild("Dirt")
                    if dirt then
                        local currentLvl = dirt:GetAttribute("PlantLevel") or 0
                        
                        -- Só foca nas plantas que realmente precisam de upgrade[cite: 1]
                        if currentLvl < TargetUpgradeLevel then
                            local lastAttempt = UpgradeDebounceTimes[dirt] or 0
                            
                            -- Proteção anti-spam: Só pede upgrade de novo se passou 1.5s do último envio para ESSA planta.
                            if tick() - lastAttempt > 1.5 then
                                UpgradeDebounceTimes[dirt] = tick()
                                
                                task.spawn(function()
                                    pcall(function() upgradeRemote:InvokeServer(dirt) end)
                                end)
                                
                                task.wait(0.08) -- Delay microscópico de rede entre plantas para estabilizar o ping
                            end
                        end
                    end
                end
            end
        end
        
        if AutoFertilizerEnabled and fertRemote then
            local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            local tool, dirt = nil, getUnfertilizedDirt()
            
            for _, t in ipairs(LocalPlayer.Backpack:GetChildren()) do
                for allowedName, isActive in pairs(SelectedAutoFertilizers) do
                    if isActive and string.find(t.Name, allowedName, 1, true) then tool = t break end
                end
                if tool then break end
            end
            
            if tool and dirt and humanoid then
                humanoid:EquipTool(tool)
                task.wait(0.3)
                fertRemote:FireServer(dirt)
                task.wait(0.3)
                humanoid:UnequipTools()
            end
        end
    end
end)

