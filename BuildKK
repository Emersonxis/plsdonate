-- ========================================================
-- LOOP EXPERIMENTAL: PLANT RUSH (TRACKING E CONFIGS DINÂMICAS)
-- ========================================================
task.spawn(function()
    local ShootRemote = Remotes:WaitForChild("PlantRush", 5) and Remotes.PlantRush:WaitForChild("Shoot", 5)
    
    while true do
        -- Velocidade controlada dinamicamente pelo Input
        task.wait(PlantRushShootSpeed)
        
        if AutoPlantRush and ShootRemote then
            local ie = workspace:FindFirstChild("InteractiveEvents")
            local pr = ie and ie:FindFirstChild("PlantRush")
            local runtime = pr and pr:FindFirstChild("Runtime")
            
            if runtime and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local originPos = LocalPlayer.Character.HumanoidRootPart.Position
                local targetsFired = 0
                
                local currentPlants = runtime:GetChildren()
                local currentPlantsMap = {}
                
                -- Registrar novos spawns para aplicar a proteção de nascimento individual
                for _, plant in ipairs(currentPlants) do
                    currentPlantsMap[plant] = true
                    if not TrackedPlants[plant] then
                        TrackedPlants[plant] = tick()
                    end
                end
                
                -- Limpar o cache de plantas removidas
                for plant, _ in pairs(TrackedPlants) do
                    if not currentPlantsMap[plant] then
                        TrackedPlants[plant] = nil
                    end
                end
                
                -- Varredura e Disparo por lotes controlados
                for _, plant in ipairs(currentPlants) do
                    if not AutoPlantRush or targetsFired >= PlantRushMaxTargets then break end
                    
                    local spawnTime = TrackedPlants[plant]
                    
                    -- Verifica se já cumpriu o tempo de Spawn Protection definido na UI[cite: 1]
                    if spawnTime and (tick() - spawnTime) >= PlantRushSpawnProtection then
                        local targetPart = plant:IsA("BasePart") and plant or plant:FindFirstChildWhichIsA("BasePart", true)
                        
                        if targetPart then
                            local targetPos = targetPart.Position
                            local direction = (targetPos - originPos).Unit
                            local args = { originPos, direction, targetPos }
                            
                            task.spawn(function()
                                ShootRemote:FireServer(unpack(args))
                            end)
                            
                            targetsFired = targetsFired + 1
                        end
                    end
                end
            end
        end
    end
end)

