-- Função de Deletar Portas
local function deleteAllDoors()
    local doorsFolder = workspace:FindFirstChild("Doors")
    if doorsFolder then
        for _, group in pairs(doorsFolder:GetChildren()) do
            if group:IsA("Folder") or group:IsA("Model") then
                group:Destroy()
            end
        end
    end
end

-- Função para Pegar Arma
local function getEquippedWeaponName()
    local model = workspace:FindFirstChild("Players"):FindFirstChild(player.Name)
    if model then
        for _, child in ipairs(model:GetChildren()) do
            if child:IsA("Model") then return child.Name end
        end
    end
    return "M1911"
end

-- // ABA COMBAT // --
local CombatTab = Window:CreateTab("⚔️ Combat", "Skull")

CombatTab:CreateSection("🔫 Auto Kill & Skips")

CombatTab:CreateToggle({
    Name = "🔪 Auto Headshots (Spawn Protection)",
    CurrentValue = false,
    Flag = "AutoKill",
    Callback = function(state)
        autoKill = state
        if state then
            task.spawn(function()
                while autoKill do
                    local enemies = workspace:FindFirstChild("Enemies")
                    local shootRemote = Remotes:FindFirstChild("ShootEnemy")
                    
                    if enemies and shootRemote then
                        local weapon = getEquippedWeaponName()
                        for _, zombie in pairs(enemies:GetChildren()) do
                            if not autoKill then break end
                            local head = zombie:FindFirstChild("Head")
                            local humanoid = zombie:FindFirstChildOfClass("Humanoid")
                            if head and humanoid and humanoid.Health > 0 then
                                if not zombie:GetAttribute("SpawnTime") then
                                    zombie:SetAttribute("SpawnTime", tick())
                                end
                                if tick() - zombie:GetAttribute("SpawnTime") >= 2 then
                                    local args = {zombie, head, head.Position, 0.5, weapon}
                                    for i = 1, shotsPerMob do
                                        if humanoid.Health <= 0 then break end
                                        pcall(function() shootRemote:FireServer(unpack(args)) end)
                                    end
                                end
                            end
                        end
                    end
                    task.wait(shootDelay)
                end
            end)
        end
    end
})

CombatTab:CreateToggle({
    Name = "⏩ Auto Skip Round",
    CurrentValue = false,
    Flag = "AutoSkipRound",
    Callback = function(state)
        autoSkip = state
        if state then
            task.spawn(function()
