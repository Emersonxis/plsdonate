-- Loops de suporte (Safe Zone e Orbit)
task.spawn(function()
    while true do
        if autoSafeZone then
            pcall(function()
                local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                local gui = player:FindFirstChild("PlayerGui")
                local label = gui and gui.HUD.Wave.Label
                if root and label then
                    local waveNum = tonumber(label.ContentText:match("%d+"))
                    if waveNum and waveNum % 10 == 0 and waveNum ~= lastSafeWave then
                        lastSafeWave = waveNum
                        savedPos = root.CFrame
                        root.CFrame = CFrame.new(139, 5, 66)
                        task.wait(tempoNaSafe)
                        if savedPos then root.CFrame = savedPos end
                    end
                end
            end)
        end
        task.wait(1)
    end
end)

RunService.RenderStepped:Connect(function(dt)
    if spinning then
        local HRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not HRP then return end
        local function getBoss()
            local targets = workspace:FindFirstChild("Enemies")
            if not targets then return nil end
            return targets:FindFirstChild("GoblinKing") or targets:FindFirstChild("CaptainBoom") or targets:FindFirstChild("Fungarth")
        end
        local boss = getBoss()
        if boss and boss:FindFirstChild("Head") then
            angle = angle + (dt * orbitSpeed)
            local bossPos = boss.Head.Position
            local offset = Vector3.new(math.cos(angle), 0, math.sin(angle)) * orbitRadius
            local targetPos = bossPos + offset + Vector3.new(0, orbitHeight, 0)
            HRP.CFrame = CFrame.new(targetPos, bossPos)
        end
    end
end)

