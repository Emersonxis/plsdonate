-- SISTEMA DINÂMICO E SEGURO DE EXTRAÇÃO DA REDE
local Network = nil
local function getNetwork()
    if Network then return Network end
    pcall(function()
        local library = ReplicatedStorage:FindFirstChild("Library")
        local client = library and library:FindFirstChild("Client")
        local netMod = client and client:FindFirstChild("Network")
        if netMod then
            Network = require(netMod)
        end
    end)
    if not Network then
        pcall(function()
            Network = require(ReplicatedStorage.Library.Client.Network)
        end)
    end
    return Network
end

