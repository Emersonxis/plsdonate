task.spawn(function()
    while true do
        if ClickSettings.Enabled then
            local net = getNetwork()
            local player = Players.LocalPlayer
            local character = player.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local breakablesFolder = Workspace:FindFirstChild("__THINGS") and Workspace.__THINGS:FindFirstChild("Breakables")
            
            if rootPart and breakablesFolder and net then
                local playerPos = rootPart.Position
                local targets = {}
                
                for _, breakable in ipairs(breakablesFolder:GetChildren()) do
                    local targetPos = breakable:IsA("Model") and breakable:GetPivot().Position or (breakable:IsA("BasePart") and breakable.Position)
                    if targetPos then
                        local distance = (playerPos - targetPos).Magnitude
                        if distance <= ClickSettings.MaxDistance then 
                            table.insert(targets, {Instance = breakable, Dist = distance})
                        end
                    end
                end
                
                table.sort(targets, function(a, b) return a.Dist < b.Dist end)
                
                local maxToBreak = math.min(ClickSettings.MaxBreakables, #targets)
                
                if maxToBreak > 0 then
                    if ClickSettings.MaxBreakables == 1 then
                        local currentTarget = targets[1].Instance
                        local uid = currentTarget:GetAttribute("BreakableUID") or currentTarget.Name
                        
                        pcall(function()
                            if net.UnreliableFire then
                                net.UnreliableFire("Breakables_PlayerDealDamage", uid)
                            else
                                net.Fire("Breakables_PlayerDealDamage", uid)
                            end
                        end)
                        
                        local foiQuebrado = false
                        local conexao
                        conexao = currentTarget.AncestryChanged:Connect(function()
                            if not currentTarget:IsDescendantOf(Workspace) then
                                foiQuebrado = true
                                if conexao then conexao:Disconnect() end
                            end
                        end)
                        
                        local inicio = os.clock()
                        while os.clock() - inicio < ClickSettings.Delay and not foiQuebrado and ClickSettings.Enabled do
                            task.wait() 
                        end
                        if conexao then conexao:Disconnect() end
                    else
                        for i = 1, maxToBreak do
                            if not ClickSettings.Enabled then break end
                            local currentTarget = targets[i].Instance
                            local uid = currentTarget:GetAttribute("BreakableUID") or currentTarget.Name
                            pcall(function()
                                if net.UnreliableFire then
                                    net.UnreliableFire("Breakables_PlayerDealDamage", uid)
                                else
                                    net.Fire("Breakables_PlayerDealDamage", uid)
                                end
                            end)
                        end
                        task.wait(ClickSettings.Delay)
                    end
                else
                    task.wait(0.05)
                end
            else
                task.wait(0.1)
            end
        else
            task.wait(0.2)
        end
    end
end)

-- ============================================================================
-- LÓGICA INTERNA: GERENCIADOR DE TELEPORTE (INTERRUPTÍVEL + PERSISTENTE)
-- ============================================================================
local function interruptibleWait(seconds)
    local start = os.clock()
    while os.clock() - start < seconds do
        if not TeleportSettings.Enabled then
            return false
        end
        task.wait(0.1)
    end
    return true
end

local function MonitorarTempoParado()
    local character = Players.LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    local startPos = rootPart.Position
    local startCFrame = rootPart.CFrame
    local timeSpent = 0
    
    while true do
        task.wait(0.1)
        local currentChar = Players.LocalPlayer.Character
        local currentRoot = currentChar and currentChar:FindFirstChild("HumanoidRootPart")
        if currentRoot and (currentRoot.Position - startPos).Magnitude < 2 then
            timeSpent = timeSpent + 0.1
        else
            break
        end
    end
    
    local finalTime = math.round(timeSpent * 10) / 10
    if finalTime < 1 then finalTime = 1 end 
    
    local pointId = "Ponto " .. tostring(#TeleportSettings.Points + 1) .. " (" .. tostring(finalTime) .. "s)"
    table.insert(TeleportSettings.Points, {
        cframe = startCFrame,
        waitTime = finalTime,
        id = pointId
    })
    saveTeleportData()
end

