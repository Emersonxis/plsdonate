-- Verifica se o pet deve ser ignorado para o Index (Ovos com Huges/Titanics)
local function isPetRequiredForIndex(petId)
    local isRequired = true
    pcall(function()
        local dirPets = Directory.Pets
        if type(dirPets) == "function" then dirPets = dirPets() end
        
        local petData = dirPets[petId]
        if type(petData) == "table" then
            -- Métrica oficial do PS99: ignora hidden, secret, huge, titanic e gargantuan
            if petData.hidden == true or petData.secret == true or petData.exclusiveLevel ~= nil or petData.huge == true or petData.titanic == true or petData.gargantuan == true then
                isRequired = false
            end
        end
    end)
    return isRequired
end

-- Verifica se o jogador pegou o Pet validando o "PetHatchCount" e "ItemIndex" oficiais
local function checkMissingLive(eggId, eggName)
    local missing = false
    pcall(function()
        local saveData = SaveMod.Get()
        if not saveData then return end

        local dirEggs = Directory.Eggs
        if type(dirEggs) == "function" then dirEggs = dirEggs() end
        
        -- Busca o ovo pela Key exata, por nome limpo ou pelo ID (1 | Cracked Egg)
        local eggData = dirEggs[eggName] or dirEggs[eggId .. " | " .. eggName]
        if not eggData then
            for k, v in pairs(dirEggs) do
                local vName = type(v) == "table" and (v.name or v.id) or tostring(k)
                if vName == eggName or string.find(tostring(k), eggName) then
                    eggData = v
                    break
                end
            end
        end

        if not eggData then return end
        
        local pList = eggData.pets or eggData.Pets
        if type(pList) ~= "table" then return end

        local petHatchCount = saveData.PetHatchCount or {}
        local itemIndex = (saveData.ItemIndex and saveData.ItemIndex.Pet) or {}

        for _, petInfo in pairs(pList) do
            local petId = type(petInfo) == "string" and petInfo or (type(petInfo) == "table" and (petInfo[1] or petInfo.id))
            
            -- Se for um pet válido (Não-Huge/Não-Titanic)
            if petId and isPetRequiredForIndex(petId) then
                local isDiscovered = false
                
                -- Checagem oficial de descoberta na memória
                if (tonumber(petHatchCount[petId]) or 0) > 0 then
                    isDiscovered = true
                elseif itemIndex[petId] ~= nil then
                    isDiscovered = true
                end
                
                if not isDiscovered then
                    missing = true
                    return -- Falta um, o ovo ainda não está completo
                end
            end
        end
    end)
    return missing
end

-- Formata a String do Parágrafo com os ovos faltantes
local function GetMissingEggsString(eggsTable)
    local missing = {}
    pcall(function()
        for _, eggFolder in ipairs(eggsTable) do
            local idStr, namePart = string.match(eggFolder.Name, "^(%d+)%s*|%s*(.+)")
            if not namePart then namePart = eggFolder.Name idStr = "9999" end
            namePart = string.gsub(namePart, "^%s*(.-)%s*$", "%1")

            -- Ignorar Exclusivos na String para manter limpo
            if not string.find(string.lower(namePart), "exclusive") then
                if checkMissingLive(idStr, namePart) then
                    table.insert(missing, namePart)
                end
            end
        end
    end)
    
    if #missing == 0 then return "🎉 Todos os pets normais indexados (100%)!" end
    return table.concat(missing, ", ")
end

-- Loop Principal Inteligente
task.spawn(function()
    while true do
        if _G.AutoIndex then
            local dirEggs = ReplicatedStorage:WaitForChild("__DIRECTORY"):WaitForChild("Eggs")
            local eggs = dirEggs:GetChildren()
            
            table.sort(eggs, function(a, b)
                local idA = tonumber(string.match(a.Name, "^(%d+)")) or 9999
                local idB = tonumber(string.match(b.Name, "^(%d+)")) or 9999
                return idA < idB
            end)

            if MissingEggsParagraph then 
                MissingEggsParagraph:Set({Title = "Ovos Incompletos:", Content = GetMissingEggsString(eggs)}) 
            end
            
            local achouAlgoIncompleto = false

            for _, eggFolder in ipairs(eggs) do
                if not _G.AutoIndex then break end 
                if _G.SkipCurrentEgg then _G.SkipCurrentEgg = false end 

                local idStr, namePart = string.match(eggFolder.Name, "^(%d+)%s*|%s*(.+)")
                if not namePart then namePart = eggFolder.Name idStr = "9999" end
                namePart = string.gsub(namePart, "^%s*(.-)%s*$", "%1")
                
                local id = idStr
                local name = namePart
                
                -- Ignora completamente os Ovos Exclusivos (Esses não contam pro Index F2P)
                if string.find(string.lower(name), "exclusive") then continue end
                
                if checkMissingLive(idStr, name) then
                    achouAlgoIncompleto = true
                    
                    if CurrentEggLabel then CurrentEggLabel:Set("Abrindo: " .. name) end
                    if StatusLabel then StatusLabel:Set("Status: Indexando...") end
                    
                    _G.EggMultiplier = "Max"
                    if EggMultiplierDropdown then EggMultiplierDropdown:Set({"Max"}) end
                    
                    local eggWorld = Workspace:FindFirstChild("__THINGS") and Workspace.__THINGS:FindFirstChild("Eggs") and Workspace.__THINGS.Eggs:FindFirstChild("Main")
                    local eggCapsule = eggWorld and eggWorld:FindFirstChild(id .. " - Egg Capsule")
                    
                    if eggCapsule then
                        local char = Players.LocalPlayer.Character
                        local rootPart = char and char:FindFirstChild("HumanoidRootPart")
                        if rootPart then 
                            rootPart.CFrame = eggCapsule:GetPivot() 
                            task.wait(0.5)
                        end
                    end

                    _G.EggSelected = name
                    if EggDropdown then EggDropdown:Set({name}) end 
                    
                    _G.AutoEgg = true
                    if EggToggle then EggToggle:Set(true) end
                    
                    -- Failsafe: Evita travamentos caso o jogo mude de ideia
                    local attemptCount = 0
                    while _G.AutoIndex and not _G.SkipCurrentEgg do
                        task.wait(1)
                        attemptCount = attemptCount + 1
                        
                        -- Se checkMissingLive der FALSO (Ovo 100%), ele sai na hora
                        if not checkMissingLive(idStr, name) then 
                            break 
                        end
                        
                        -- Se passar de 300 segundos, ele desiste deste ovo
                        if attemptCount > 10900 then
                            break
                        end
                    end
                    
                    _G.AutoEgg = false
                    if EggToggle then EggToggle:Set(false) end
                    
                    if _G.AutoIndex and MissingEggsParagraph then
                        MissingEggsParagraph:Set({Title = "Ovos Incompletos:", Content = GetMissingEggsString(eggs)})
                    end
                    
                    if _G.SkipCurrentEgg then
                        _G.SkipCurrentEgg = false
                        if StatusLabel then StatusLabel:Set("Status: Ovo Pulado Manualmente!") end
                        task.wait(1)
                    end
                    
                    task.wait(1) 
                end
            end
            
            if _G.AutoIndex then
                if not achouAlgoIncompleto then
                    if StatusLabel then StatusLabel:Set("Status: Index 100% Completo!") end
                else
                    if StatusLabel then StatusLabel:Set("Status: Varredura Finalizada!") end
                end
                
                if CurrentEggLabel then CurrentEggLabel:Set("Abrindo: Nenhum") end
                
                _G.AutoIndex = false
                if AutoIndexToggle then AutoIndexToggle:Set(false) end
            end
        else
            task.wait(1)
        end
    end
end)

