-- Função segura para obter o módulo Network sem travar o script principal
local function GetNetwork()
    if CachedNetwork then return CachedNetwork end
    pcall(function()
        local library = ReplicatedStorage:FindFirstChild("Library")
        local client = library and library:FindFirstChild("Client")
        local netMod = client and client:FindFirstChild("Network")
        if netMod then
            CachedNetwork = require(netMod)
        end
    end)
    return CachedNetwork
end

