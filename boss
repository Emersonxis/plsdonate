local TeleportTab = Window:CreateTab("Teleporte", 4483362458)
local TPDropdown 

local function AtualizarListaDropdown()
    local ids = {}
    for i = 1, #TeleportSettings.Points do
        table.insert(ids, TeleportSettings.Points[i].id)
    end
    if TPDropdown then
        TPDropdown:Refresh(ids, true)
    end
end

TeleportTab:CreateToggle({
   Name = "Ativar Loop de Rotas",
   CurrentValue = false,
   Flag = "RouteLoopActive",
   Callback = function(Value)
      TeleportSettings.Enabled = Value
   end,
})

TeleportTab:CreateButton({
   Name = "Definir Coordenada 'Home'",
   Callback = function()
      local character = Players.LocalPlayer.Character
      local rootPart = character and character:FindFirstChild("HumanoidRootPart")
      if rootPart then
          TeleportSettings.Home = rootPart.CFrame
          saveTeleportData()
      end
   end,
})

TeleportTab:CreateButton({
   Name = "Salvar Coordenada Atual da Rota",
   Callback = function()
      task.spawn(function()
          MonitorarTempoParado()
          AtualizarListaDropdown()
      end)
   end,
})

TPDropdown = TeleportTab:CreateDropdown({
   Name = "Gerenciar Pontos Salvos",
   Options = {},
   CurrentOption = "",
   Flag = "PointRouteList",
   Callback = function(Option)
      TeleportSettings.SelectedPoint = Option
   end,
})

AtualizarListaDropdown()

TeleportTab:CreateButton({
   Name = "Excluir Ponto Selecionado",
   Callback = function()
      if TeleportSettings.SelectedPoint then
          for i = #TeleportSettings.Points, 1, -1 do
              if TeleportSettings.Points[i].id == TeleportSettings.SelectedPoint then
                  table.remove(TeleportSettings.Points, i)
                  break
              end
          end
          TeleportSettings.SelectedPoint = nil
          saveTeleportData()
          AtualizarListaDropdown()
      end
   end,
})

