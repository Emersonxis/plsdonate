-- [[ LEITURA DINÂMICA DOS EGGS REAIS DA PASTA ]]
local eggOptions = {}
local function puxarOvosReais()
    table.clear(eggOptions)
    
    -- Caminho 1: Pela pasta física de ZoneEggs mapeada no script
    pcall(function()
        local things = Workspace:FindFirstChild("__THINGS")
        local zoneEggs = things and things:FindFirstChild("ZoneEggs")
        local mainEggs = zoneEggs and zoneEggs:FindFirstChild("Main")
        if mainEggs then
            for _, eggModel in ipairs(mainEggs:GetChildren()) do
                if not table.find(eggOptions, eggModel.Name) then
                    table.insert(eggOptions, eggModel.Name)
                end
            end
        end
    end)
    
    -- Caminho 2: Pela Library interna se a pasta física não carregou ainda
    if #eggOptions == 0 then
        pcall(function()
            local Directory = require(ReplicatedStorage.Library.Directory)
            if Directory and Directory.Eggs then
                for eggName, _ in pairs(Directory.Eggs) do
                    table.insert(eggOptions, eggName)
                end
            end
        end)
    end
    
    if #eggOptions == 0 then
        table.insert(eggOptions, "Aguardando mapa...")
    else
        table.sort(eggOptions)
    end
    return eggOptions
end
puxarOvosReais()

