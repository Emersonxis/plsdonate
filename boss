-- ============================================================================
-- ARQUIVO LOCAL: SISTEMA DE SALVAMENTO DE CFRAMES CUSTOMIZADO
-- ============================================================================
local function cframeToTable(cf)
    if not cf then return nil end
    return {cf:GetComponents()}
end

local function tableToCFrame(tbl)
    if not tbl then return nil end
    return CFrame.new(unpack(tbl))
end

local function saveTeleportData()
    local data = {
        Home = cframeToTable(TeleportSettings.Home),
        Points = {}
    }
    for _, pt in ipairs(TeleportSettings.Points) do
        table.insert(data.Points, {
            cframe = cframeToTable(pt.cframe),
            waitTime = pt.waitTime,
            id = pt.id
        })
    end
    pcall(function()
        writefile(FILE_NAME, HttpService:JSONEncode(data))
    end)
end

local function loadTeleportData()
    if isfile(FILE_NAME) then
        local success, result = pcall(function()
            return HttpService:JSONDecode(readfile(FILE_NAME))
        end)
        if success and result then
            if result.Home then
                TeleportSettings.Home = tableToCFrame(result.Home)
            end
            if result.Points then
                TeleportSettings.Points = {}
                for _, pt in ipairs(result.Points) do
                    table.insert(TeleportSettings.Points, {
                        cframe = tableToCFrame(pt.cframe),
                        waitTime = pt.waitTime,
                        id = pt.id
                    })
                end
            end
        end
    end
end

