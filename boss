-- LÓGICA INTERNA: AUTO COLLECT ORBS & LOOTBAGS
-- ============================================================================
local function coletarEDeletar(item)
    if not _G.AutoCollect or not item then return end
    local itemId = item:GetAttribute("Id") or item:GetAttribute("OrbID") or item.Name
    if itemId and type(itemId) == "string" then
        local net = getNetwork()
        if net then pcall(function() net.Fire("Orbs: Collect", {itemId}) end) end
        task.wait(0.05)
        if item and item.Parent then
            pcall(function()
                if item:IsA("Model") then
                    for _, child in ipairs(item:GetDescendants()) do if child:IsA("BasePart") then child.Transparency = 1 child.CanCollide = false end end
                elseif item:IsA("BasePart") then item.Transparency = 1 item.CanCollide = false end
            end)
            task.wait(0.1)
            if item and item.Parent then pcall(function() item:Destroy() end) end
        end
    end
end

task.spawn(function()
    local conexoes = {}
    while true do
        if _G.AutoCollect then
            local things = Workspace:FindFirstChild("__THINGS")
            if things then
                local pastasAlvo = { things:FindFirstChild("Orbs"), things:FindFirstChild("RenderedOrbs") }
                for _, pasta in ipairs(pastasAlvo) do
                    if pasta and not conexoes[pasta] then
                        conexoes[pasta] = pasta.ChildAdded:Connect(function(item) task.spawn(coletarEDeletar, item) end)
                        for _, item in ipairs(pasta:GetChildren()) do task.spawn(coletarEDeletar, item) end
                    end
                end
            end
        else
            for pasta, conexao in pairs(conexoes) do if conexao then conexao:Disconnect() end conexoes[pasta] = nil end
        end
        task.wait(1)
    end
end)

